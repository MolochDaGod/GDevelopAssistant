# ==============================================
# grudgeDot — Grudge Studio Launcher Environment
# ==============================================
# Copy to .env and fill in your values. Never commit .env.
#
# Architecture:
#   - All auth is delegated to id.grudge-studio.com (no OAuth client IDs here)
#   - Game data comes from api.grudge-studio.com, proxied via /api/*
#   - The upstream backend path prefix is configurable via GRUDGEDOT_BACKEND_PREFIX

# ══════════════════════════════════════════════
# CORE — Required for the app to function
# ══════════════════════════════════════════════

# Grudge VPS PostgreSQL (shared with Warlord Crafting Suite)
DATABASE_URL=postgresql://grudge:password@db.grudge-studio.com:5432/grudge_warlords?sslmode=require

# JWT signing secret — used by server/middleware/grudgeJwt.ts to verify tokens
# issued by id.grudge-studio.com. MUST match the SSO's secret for fast local verify.
SESSION_SECRET=your-session-secret-here

# Server
NODE_ENV=development
PORT=5000

# Admin (for admin-only API routes)
ADMIN_PASSWORD=

# ══════════════════════════════════════════════
# AUTH — Delegated to Grudge ID SSO
# ══════════════════════════════════════════════
# The launcher has no local login. These URLs are the origins it talks to.

# SSO origin. grudgeAuth.ts proxies /api/auth/verify, /api/auth/user, /api/auth/me,
# /api/auth/logout to ${GRUDGE_AUTH_URL}/auth/*. Also used as the fallback for
# remote token verification in grudgeJwt.ts.
GRUDGE_AUTH_URL=https://id.grudge-studio.com

# Grudge game/backend API. Used by /api/grudge/* proxy and by vercelApp.ts proxies.
GRUDGE_BACKEND_URL=https://api.grudge-studio.com

# Upstream path prefix on api.grudge-studio.com. Legacy installs still expose
# /api/gdevelop/*; flip to /api/grudgedot once the VPS backend is renamed.
GRUDGEDOT_BACKEND_PREFIX=/api/gdevelop

# ══════════════════════════════════════════════
# AI PROVIDERS — Powers chat, asset tagging, generation
# ══════════════════════════════════════════════

# xAI Grok — primary AI for game dev chat + asset descriptions
XAI_API_KEY=

# OpenAI — sprite generation, AI personality, fallback chat
OPENAI_API_KEY=

# Meshy 3D — 3D asset generation (text-to-3d, retexture)
MESHY_API_KEY=

# Vidu — image-to-video cutscene generation
VIDU_API_KEY=

# ══════════════════════════════════════════════
# CROSSMINT — Solana wallet + cNFT minting
# ══════════════════════════════════════════════
# Collection IDs (shared across all Grudge games):
#   Parent collection:    5061318d-ff65-4893-ac4b-9b28efb18ace
#   Character generation: a9bb2c8d-1350-4413-aec7-5ba1f6888511
#   Home Island:          18d0e641-8713-4d5b-9a1d-ba67c516a3ce

CROSSMINT_SERVER_API_KEY=
CROSSMINT_SECRET_KEY=
CROSSMINT_PROJECT_ID=
CROSSMINT_CLIENT_KEY=
CROSSMINT_COLLECTION_ID=a9bb2c8d-1350-4413-aec7-5ba1f6888511
CROSSMINT_ISLAND_CNFT=18d0e641-8713-4d5b-9a1d-ba67c516a3ce
CROSSMINT_USE_STAGING=false

# ══════════════════════════════════════════════
# BLOCKCHAIN / SOLANA
# ══════════════════════════════════════════════

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
AI_AGENT_SOL_ADDRESS=
GBUX_TOKEN_ADDRESS=

# ══════════════════════════════════════════════
# GAME SERVICES — External Grudge Studio services
# ══════════════════════════════════════════════

# GRUDACHAIN / GRUDA Legion AI (VPS — api.grudge-studio.com)
GRUDACHAIN_URL=https://api.grudge-studio.com
GAME_API_GRUDA=https://api.grudge-studio.com

# Warlord Crafting Suite
WCS_URL=https://warlord-crafting-suite.vercel.app

# ══════════════════════════════════════════════
# GRUDGE BACKEND PROXY — Targets for /api/grudge/* routes
# ══════════════════════════════════════════════
# These have sensible defaults in server/routes/grudgeProxy.ts.
# Only override if pointing to a non-standard backend (local dev, staging, etc.).
# See docs/BACKEND_CONNECTION_GUIDE.md for the full proxy architecture.
#
# IMPORTANT: Always use grudge-studio.com (with hyphen) — never grudgestudio.com

GRUDGE_GAME_API=https://api.grudge-studio.com
GRUDGE_ACCOUNT_API=https://account.grudge-studio.com
GRUDGE_ID_API=https://id.grudge-studio.com
GRUDGE_LAUNCHER_API=https://launcher.grudge-studio.com

# ══════════════════════════════════════════════
# CLIENT-SIDE (VITE_ prefix — exposed to browser)
# ══════════════════════════════════════════════

# Crossmint public key (same value as CROSSMINT_CLIENT_KEY)
VITE_CROSSMINT_CLIENT_KEY=

# Colyseus multiplayer server (game lobby websocket)
VITE_COLYSEUS_WS_URL=ws://localhost:2567

# AI Worker toggle (enables client-side AI capture)
VITE_ENABLE_AI_WORKER=false

# ══════════════════════════════════════════════
# CLOUDFLARE R2 / OBJECTSTORE
# ══════════════════════════════════════════════
# All asset read/write routes via /api/objectstore/* proxy to the
# Cloudflare Worker at objectstore.grudge-studio.com (R2 + D1).
# Public GET requests pass through unauthenticated.
# Writes (POST/DELETE) inject X-API-Key server-side so the browser
# never sees the key.

OBJECTSTORE_WORKER_URL=https://objectstore.grudge-studio.com
OBJECTSTORE_API_KEY=

# ══════════════════════════════════════════════
# PUTER — Server-side Node.js SDK
# ══════════════════════════════════════════════
# Used for server-side AI fallback (puter.ai.chat) and KV analytics.
# Obtain once: npx @heyputer/puter.js getAuthToken
# Store here — quota billed to this account (our infra, not users).
# Guard all usage with: if (process.env.PUTER_AUTH_TOKEN) { ... }

PUTER_AUTH_TOKEN=

# ══════════════════════════════════════════════
# RAILWAY — Production deployment
# ══════════════════════════════════════════════
# Railway injects PORT and NODE_ENV automatically.
# Set all secrets via the Railway dashboard or:
#   railway variables set KEY=VALUE
#
# Recommended Railway PostgreSQL plugin connection string:
# DATABASE_URL=postgresql://postgres:<pass>@<host>.railway.internal:5432/railway
#
# After deploy, add the custom domain grudgedot.com in:
#   Railway project → Settings → Domains


# Colyseus lobby toggle (switches lobby from Socket.IO to Colyseus)
VITE_USE_COLYSEUS=false

# ══════════════════════════════════════════════
# PUTER CLOUD (client-side KV/FS storage)
# ══════════════════════════════════════════════
# Puter SDK loads via CDN on the client — no server config needed.
# Grudge VPS PostgreSQL (DATABASE_URL) remains the server-side source of truth.

PUTER_APP_ID=

# ══════════════════════════════════════════════
# OBJECTSTORE — R2 Asset Storage (Cloudflare Worker)
# ══════════════════════════════════════════════
# Worker API for file uploads/downloads via R2 + D1 metadata.
# Public reads require no key. Uploads/deletes require OBJECTSTORE_API_KEY.

OBJECTSTORE_WORKER_URL=https://objectstore.grudge-studio.com
OBJECTSTORE_API_KEY=

# Client-side direct reads (public — no API key exposed)
VITE_OBJECTSTORE_URL=https://objectstore.grudge-studio.com

# ══════════════════════════════════════════════
# COOLIFY VPS MANAGEMENT
# ══════════════════════════════════════════════
# Coolify API for managing servers, applications, logs, and restarts.
# Admin portal available at: /admin (served from client/public/admin.html)

COOLIFY_API_URL=https://coolify.grudge-studio.com
COOLIFY_API_TOKEN=

# ══════════════════════════════════════════════
# GRUDGE BRIDGE — 3-Node VPS Operations Manager
# ══════════════════════════════════════════════
# Bridge API for backups, dumps, deploys, and mesh management.

BRIDGE_URL=https://bridge.grudge-studio.com
BRIDGE_API_KEY=

# ══════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════

ENABLE_AI_FEATURES=true
ENABLE_NFT_FEATURES=false
ENABLE_GOOGLE_SHEETS=false
ENABLE_PUTER_CLOUD=false
