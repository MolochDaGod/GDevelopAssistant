# ==============================================
# GDEVELOP ASSISTANT - Grudge Studio Environment
# ==============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database (Neon PostgreSQL - shared with Warlord-Crafting-Suite)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require
PGDATABASE=neondb
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password

# Session Management
SESSION_SECRET=change-this-session-secret

# ==============================================
# AI PROVIDERS
# ==============================================

# X.AI Grok (Game dev assistant chat)
XAI_API_KEY=

# OpenAI (Optional fallback)
OPENAI_API_KEY=

# AI Integration URLs (local modelfarm proxy)
AI_INTEGRATIONS_OPENAI_BASE_URL=http://localhost:1106/modelfarm/openai
AI_INTEGRATIONS_GEMINI_BASE_URL=http://localhost:1106/modelfarm/gemini

# Meshy 3D (3D asset generation)
MESHY_API_KEY=

# ==============================================
# AUTHENTICATION
# ==============================================
# Auth handled by auth-gateway-flax.vercel.app
# No additional config needed — tokens stored in client localStorage

# Grudge Studio IDE Integration
GAME_API_GRUDA=

# ==============================================
# OBJECT STORAGE (Replit/Puter)
# ==============================================

DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket-id/public
PRIVATE_OBJECT_DIR=/your-bucket-id/.private

# ==============================================
# OPTIONAL FEATURES
# ==============================================

# Puter Cloud (client-side cloud storage)
PUTER_APP_ID=

# Google Cloud Storage (asset sync)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# ==============================================
# GRUDA WARS / GRUDACHAIN
# ==============================================

# GRUDACHAIN AI Node System — Railway production deployment
GRUDACHAIN_URL=https://gruda-legion-production.up.railway.app

# GAME_API_GRUDA — same Railway deployment for IDE integration
GAME_API_GRUDA=https://gruda-legion-production.up.railway.app

# Warlord Crafting Suite (dungeon, heroes, crafting)
WCS_URL=https://warlord-crafting-suite.vercel.app
