{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "../.vercel/output",
    "declaration": false,
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["./shared/*"]
    },
    "types": ["node"]
  },
  "include": ["*.ts", "../server/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["../node_modules"]
}
